{
  "cleanUrls": true,
  "trailingSlash": false,
  "routes": [
    {
      "src": "/admin/(.*\\.js)",
      "dest": "/admin/$1"
    },
    {
      "src": "/js/(.*\\.js)",
      "dest": "/js/$1"
    },
    {
      "src": "/css/(.*\\.css)",
      "dest": "/css/$1"
    },
    {
      "src": "/(.*)",
      "dest": "/$1"
    }
  ]
}
